<section class="mascot-guidance-card project-mascot-panel shadow-sm mb-4">
  <div class="d-flex flex-column flex-md-row align-items-center align-items-md-start">
    <div class="mascot-guidance-card__art project-mascot-panel__art">
      <%= render "application/mascot", size: :small, css_class: "project-mascot-panel__mascot", title: title %>
    </div>
    <div class="mascot-guidance-card__copy text-center text-md-left">
      <span class="mascot-guidance-card__eyebrow"><%= eyebrow %></span>
      <h4 class="project-mascot-panel__headline"><%= headline %></h4>
      <p class="mb-3"><%= message %></p>
      <div class="project-mascot-panel__focus">
        <span class="project-mascot-panel__focus-label">Focus</span>
        <strong><%= focus %></strong>
      </div>
    </div>
  </div>
</section>
