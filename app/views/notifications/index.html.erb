<section class="bg--secondary">
  <div class="container notifications-page">
    <div class="row justify-content-center">
      <div class="col-lg-8 col-xl-7">
        <div class="notifications-page__header">
          <h1 class="notifications-page__title">Notifications</h1>
          <p class="notifications-page__subtitle">Recent activity and updates in one place.</p>
        </div>

        <div class="card notifications-page__card">
          <% if @notifications.any? %>
            <div class="notifications-list">
              <% @notifications.each do |notification| %>
                <div class="notification-item-wrapper <%= 'unread' unless notification.read? %>">
                  <div class="notification-row">
                    <div class="notification-row__content">
                      <%= link_to notification_path(notification), data: { turbo_method: :patch }, class: "text-decoration-none text-dark d-block" do %>
                        <p class="mb-1 notification-message <%= 'font-weight-bold' unless notification.read? %>">
                          <%= notification.message %>
                        </p>
                        <small class="text-muted notification-row__timestamp">
                          <%= time_ago_in_words(notification.created_at) %> ago
                        </small>
                      <% end %>
                    </div>
                    <% unless notification.read? %>
                      <div class="notification-row__action">
                        <%= link_to "Mark as read", notification_path(notification), data: { turbo_method: :patch }, class: "btn btn-sm btn-outline-primary" %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
            <% if @pagy.pages > 1 %>
              <div class="pagination-container d-flex justify-content-center mt-4 mb-4">
                <%= pagy_nav(@pagy).html_safe %>
              </div>
            <% end %>
          <% else %>
            <div class="notifications-page__empty-state">
              <h3>All caught up</h3>
              <p class="mb-0">There are no notifications right now.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
