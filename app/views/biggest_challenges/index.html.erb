<div class="container">
  <div class="text-center mb-5">
    <h1>Challenges</h1>
    <p class="lead text-muted">Every obstacle you named was one you faced. Look how far you've come.</p>
  </div>

  <% if @biggest_challenges.any? %>
    <div class="row">
      <% @biggest_challenges.each do |challenge| %>
        <div class="col-md-12 mb-4">
          <div class="card border shadow-sm">
            <div class="card-body p-4">
              <div class="mb-3"><%= challenge.content.html_safe %></div>
              <div class="text-muted border-top pt-2">
                <small><%= challenge.created_at.strftime("%d %b %Y") %></small>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="d-flex justify-content-center mt-4">
        <%= pagy_nav(@pagy).html_safe %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-5 text-muted">
      <p>No challenges logged yet.</p>
    </div>
  <% end %>
</div>
